# Handle line endings automatically for files detected as text 
# and leave binary files (images/jars) alone.
* text=auto

# Force LF for specific web/config files to prevent "Diff" noise
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf

# Ensure shell scripts always stay LF so they don't break on Linux/Mac
*.sh text eol=lf
gradlew text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.ttf binary
*.otf binary
